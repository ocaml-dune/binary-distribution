(version 0.0.8)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (dune ocaml ppxlib)))

(source
 (fetch
  (url
   https://github.com/davesnx/html_of_jsx/releases/download/0.0.8/html_of_jsx-0.0.8.tbz)
  (checksum
   sha256=6cfb7a461b619efe1f9b16a8c3ccb6c3204b00e4ecc5caaad4ce6181fdd7673d)))
