(version 5.4.0)

(build
 (progn
  (when
   %{pkg-self:dev}
   (run dune subst))
  (run dune build -p %{pkg-self:name} -j %{jobs} @install)))

(depends dune ocaml dune-compiledb dune-configurator conf-sqlite3)

(source
 (fetch
  (url
   https://github.com/mmottl/sqlite3-ocaml/releases/download/5.4.0/sqlite3-5.4.0.tbz)
  (checksum
   sha256=f0069532f78ac24f16d79262af01434952d0481f8bf80ae541dff4a56cc4e9ff)))
