(version 0.11)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (ocaml ppxlib dune merlin-lib cppo)))

(source
 (fetch
  (url https://github.com/ocaml-mlx/mlx/releases/download/0.11/mlx-0.11.tbz)
  (checksum
   sha256=bea6b7e57deb13a1cc20af3fe9101b90b77d3e886097c6d44dd63eb96f5aaceb)))
