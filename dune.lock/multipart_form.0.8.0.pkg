(version 0.8.0)

(build
 (all_platforms ((action (run dune build -p %{pkg-self:name} -j %{jobs})))))

(depends
 (all_platforms
  (ocaml
   dune
   angstrom
   base64
   unstrctrd
   uutf
   pecu
   prettym
   fmt
   logs
   ke
   bigstringaf)))

